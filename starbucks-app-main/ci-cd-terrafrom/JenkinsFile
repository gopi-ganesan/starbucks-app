pipeline {
    agent any 

    parameters {
        string(
            name: 'environment',
            defaultValue: 'dev',
            description: 'Environment to deploy (dev, staging, prod)'
        )
        choice(
            name: 'terraform_action',
            choices: ['plan', 'apply', 'destroy'],
            description: 'Terraform action'
        )
    }

    environment {
        AWS_DEFAULT_REGION = 'us-east-1'
    }

    stages {

        stage('Preparing') {
            steps {
                sh 'echo Preparing pipeline...'
            }
        }

        stage('Git Checkout') {
            steps {
                git(
                    url: 'https://github.com/gopi-ganesan/starbucks-app.git',
                    branch: 'main',
                    credentialsId: 'github-token'
                )
            }
        }

        stage('Terraform Init') {
            steps {
                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding',
                     credentialsId: 'aws-credentials']
                ]) {
                    sh '''
                        terraform -chdir=ci-cd-terrafrom/eks init
                    '''
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding',
                     credentialsId: 'aws-credentials']
                ]) {
                    sh '''
                        terraform -chdir=ci-cd-terrafrom/eks validate
                    '''
                }
            }
        }

        stage('Terraform Action') {
            steps {
                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding',
                     credentialsId: 'aws-credentials']
                ]) {
                    script {
                        if (params.terraform_action == 'plan') {
                            sh '''
                                terraform -chdir=ci-cd-terrafrom/eks plan -out=tfplan
                            '''
                        } 
                        else if (params.terraform_action == 'apply') {
                            sh '''
                                if [ ! -f ci-cd-terrafrom/eks/tfplan ]; then
                                    echo "No tfplan found, running plan first..."
                                    terraform -chdir=ci-cd-terrafrom/eks plan -out=tfplan
                                fi
                                terraform -chdir=ci-cd-terrafrom/eks apply -auto-approve tfplan
                            '''
                        } 
                        else if (params.terraform_action == 'destroy') {
                            sh '''
                                terraform -chdir=ci-cd-terrafrom/eks destroy -auto-approve
                            '''
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline executed successfully ✅'
        }
        failure {
            echo 'Pipeline failed ❌'
        }
    }
}