pipeline{
    angent any 
    propertie([
        parameters([
            string(
                defaultValue: 'dev',    
                name: 'environment',
                description: 'Environment to deploy to (e.g., dev, staging, prod)',
            ),
            choice(
                choices:['plan','apply','destroy'],
                name: 'terrafrom_action',
                description: 'Choose the Terraform action to perform',
            )   
        ])
    ])
    stages{
        stage('preparing'){
            steps{
                sh'echo preparing '
            }
        }
        stage('git checkout'){
            steps{
                git(
                    url:'',
                    branch:'',
                    credentialsId:'github-token',
                )
            }
        }
        stage('terrafrom init'){
            steps{
                withAWS(credentials:'aws-credentials', region:'us-east-1'){
                    sh 'terraform -chdir=eks/ init'
                }
            }
        }
        stage('validate terraform'){
            steps{
                withAWS(credentials:'aws-credentials', region:'us-east-1'){
                    sh 'terraform -chdir=eks/ validate'
                }
            }
        }
        stage('terrafrom action'){
            withAWS(credentials:'aws-credentials', region:'us-east-1'){
                steps{
                    script{
                        if(params.terrafrom_action == 'plan'){
                            sh 'terraform -chdir=eks/ plan -out=tfplan'
                        } else if(params.terrafrom_action == 'apply'){
                            sh 'terraform -chdir=eks/ apply -auto-approve tfplan'
                        } else if(params.terrafrom_action == 'destroy'){
                            sh 'terraform -chdir=eks/ destroy -auto-approve'
                        }
                    }
                }
            }
        }
    }
}