pipeline {
    agent any 

    properties([
        parameters([
            string(
                defaultValue: 'dev',    
                name: 'environment',
                description: 'Environment to deploy to (e.g., dev, staging, prod)'
            ),
            choice(
                choices: ['plan', 'apply', 'destroy'],
                name: 'terraform_action',
                description: 'Choose the Terraform action to perform'
            )   
        ])
    ])

    stages {

        stage('Preparing') {
            steps {
                sh 'echo preparing'
            }
        }

        stage('Git Checkout') {
            steps {
                git(
                    url: 'YOUR_REPO_URL',
                    branch: 'main',
                    credentialsId: 'github-token'
                )
            }
        }

        stage('Terraform Init') {
            steps {
                withAWS(credentials: 'aws-credentials', region: 'us-east-1') {
                    sh 'terraform -chdir=eks/ init'
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                withAWS(credentials: 'aws-credentials', region: 'us-east-1') {
                    sh 'terraform -chdir=eks/ validate'
                }
            }
        }

        stage('Terraform Action') {
            steps {
                withAWS(credentials: 'aws-credentials', region: 'us-east-1') {
                    script {
                        if (params.terraform_action == 'plan') {
                            sh 'terraform -chdir=eks/ plan -out=tfplan'
                        } 
                        else if (params.terraform_action == 'apply') {
                            sh '''
                                if [ ! -f eks/tfplan ]; then
                                    echo "No tfplan found. Running plan first..."
                                    terraform -chdir=eks/ plan -out=tfplan
                                fi
                                terraform -chdir=eks/ apply -auto-approve tfplan
                            '''
                        } 
                        else if (params.terraform_action == 'destroy') {
                            sh 'terraform -chdir=eks/ destroy -auto-approve'
                        }
                    }
                }
            }
        }
    }
}