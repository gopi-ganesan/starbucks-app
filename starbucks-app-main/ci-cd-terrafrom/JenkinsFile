pipeline {
    agent any 

    parameters {
        string(
            name: 'environment',
            defaultValue: 'dev',
            description: 'Environment to deploy (dev, staging, prod)'
        )
        choice(
            name: 'terraform_action',
            choices: ['plan', 'apply', 'destroy'],
            description: 'Terraform action'
        )
    }

    stages {

        stage('Preparing') {
            steps {
                sh 'echo preparing'
            }
        }

        stage('Git Checkout') {
            steps {
                git(
                    url: 'https://github.com/gopi-ganesan/starbucks-app.git',
                    branch: 'main',
                    credentialsId: 'github-token'
                )
            }
        }

        stage('Terraform Init') {
            steps {
                withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-credentials'
                    ]]) {
                    sh '''
                        export AWS_DEFAULT_REGION=us-east-1
                        terraform -chdir=ci-cd-terraform/eks init
                    '''
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                withAWS(credentials: 'aws-credentials', region: 'us-east-1') {
                    sh 'terraform -chdir=ci-cd-terraform/eks validate'
                }
            }
        }

        stage('Terraform Action') {
            steps {
                withAWS(credentials: 'aws-credentials', region: 'us-east-1') {
                    script {
                        if (params.terraform_action == 'plan') {
                            sh "terraform -chdir=ci-cd-terraform/eks plan -var='environment=${params.environment}' -out=tfplan"
                        } 
                        else if (params.terraform_action == 'apply') {
                            sh "terraform -chdir=ci-cd-terraform/eks apply -var='environment=${params.environment}' -auto-approve"
                        } 
                        else if (params.terraform_action == 'destroy') {
                            sh "terraform -chdir=ci-cd-terraform/eks destroy -var='environment=${params.environment}' -auto-approve"
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline executed successfully '
        }
        failure {
            echo 'Pipeline failed '
        }
    }
}